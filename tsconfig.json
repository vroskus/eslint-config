{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "module": "esnext",
    "moduleResolution":"bundler",
    "esModuleInterop": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "declaration": true,
    "target": "es6",
    "lib": [
      "ES2020"
    ],
    "types": [
      "node"
    ],
    "strict": true
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "src"
  ]
}
