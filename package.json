{
  "name": "@vroskus/eslint-config",
  "version": "1.1.3",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vroskus/eslint-config.git"
  },
  "description": "Eslint config",
  "author": "Vilius Roškus",
  "keywords": [
    "eslint"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "npm run test:eslint && npm run test:type && npm run test:node && npm run test:browser",
    "test:eslint": "eslint src --fix",
    "test:type": "tsc",
    "test:node": "eslint -c ./test/node.config.mjs ./test --fix",
    "test:browser": "eslint -c ./test/browser.config.mjs ./test --fix",
    "build": "tsc"
  },
  "dependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.5.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-problems": "^10.0.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-module-bindings-newline": "^1.0.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "devDependencies": {
    "@types/eslint__js": "^9.14.0",
    "@types/node": "^25.9.3"
  },
  "bugs": {
    "url": "https://github.com/vroskus/eslint-config/issues"
  },
  "homepage": "https://github.com/vroskus/eslint-config#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.js"
}
